# ==================================================
# 雇主品牌優化系統 - 環境變數設定範本
# ==================================================
# 複製此檔案並重新命名為 .env.local，然後填入您的 API Key

# Anthropic Claude API Key
# 前往 https://console.anthropic.com 申請
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 您的網站部署網址（用於 SEO Sitemap 生成）
# 範例：https://your-app-name.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
